{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "transactional.schema.json",
  "title": "Transactional request array",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/definitions/request"
  },
  "definitions": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ids": { "$ref": "#/definitions/ids" },
        "Ids": { "$ref": "#/definitions/ids" },
        "versionAsOf": { "type": "string", "format": "date-time" },
        "VersionAsOf": { "type": "string", "format": "date-time" },
        "filters": { "$ref": "#/definitions/nullableFilters" },
        "Filters": { "$ref": "#/definitions/nullableFilters" },
        "transformations": { "$ref": "#/definitions/nullableTransformations" },
        "Transformations": { "$ref": "#/definitions/nullableTransformations" },
        "columns": { "$ref": "#/definitions/columns" },
        "Columns": { "$ref": "#/definitions/columns" },
        "includeDeleted": { "type": "boolean" },
        "IncludeDeleted": { "type": "boolean" }
      },
      "anyOf": [
        { "required": ["ids"] },
        { "required": ["Ids"] }
      ]
    },
    "ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "columns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expressions": { "$ref": "#/definitions/expressions" },
        "Expressions": { "$ref": "#/definitions/expressions" },
        "filterTimeZone": { "type": "string" },
        "FilterTimeZone": { "type": "string" },
        "shape": {},
        "Shape": {}
      }
    },
    "nullableFilters": {
      "anyOf": [
        { "$ref": "#/definitions/filters" },
        { "type": "null" }
      ]
    },
    "expressions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "transformations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timezone": { "type": "string" },
        "Timezone": { "type": "string" },
        "targetTimeZone": { "type": "string" },
        "TargetTimeZone": { "type": "string" },
        "offset": { "type": "boolean" },
        "Offset": { "type": "boolean" },
        "nested": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "Nested": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "keys": { "$ref": "#/definitions/keys" },
        "Keys": { "$ref": "#/definitions/keys" },
        "values": { "$ref": "#/definitions/values" },
        "Values": { "$ref": "#/definitions/values" }
      }
    },
    "nullableTransformations": {
      "anyOf": [
        { "$ref": "#/definitions/transformations" },
        { "type": "null" }
      ]
    },
    "keys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "values": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "string" }
      }
    }
  }
}
