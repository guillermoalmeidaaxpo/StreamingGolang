{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lite.schema.json",
  "title": "Lite query request",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "from"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "from": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{3})?$"
    },
    "to": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{3})?$"
    }
  }
}
